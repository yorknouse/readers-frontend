          </g>
          <text style="fill:#57534e;font-size:6.52px;" transform="translate(260.15 48.37) scale(1.02 1)">
            <tspan style="letter-spacing:.08em" x="0" y="0">E</tspan><tspan style="letter-spacing:-.03em" x="3.73" y="0">s</tspan><tspan style="letter-spacing:-.03em" x="6.09" y="0">t</tspan><tspan style="letter-spacing:.02em" x="8.08" y="0">.</tspan><tspan style="letter-spacing:.01em" x="9.57" y="0"> </tspan><tspan style="letter-spacing:-.03em" x="11.05" y="0">1964</tspan>
          </text>
        </svg>
      </a>

      <!-- ── Desktop nav ── -->
      <nav class="navbar hidden lg:flex items-stretch h-16" aria-label="Main navigation">

      
        <!-- Nouse sections -->
        {nousePages.map((page) => {
          const children = getChildren(page.slug);
          if (children.length > 0) {
            return (
              <div class="nav-item relative group" data-section={page.slug}>
                <a href={`/${page.slug}`} class="nav-link flex items-center gap-1 px-5 h-full text-sm tracking-wider text-stone-300 hover:text-white transition-colors duration-150 font-sans uppercase focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400">
                  {page.name}
                  <svg class="w-3 h-3 opacity-60 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </a>
                <div class={`dropdown absolute top-full left-0 min-w-[160px] bg-neutral-900 border-t-2 ${page.border_colour} shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0`}>
                  {children.map((child, i) => (
                    <a href={`/${child.slug}`} class={`dropdown-link block px-5 py-3 text-xs font-sans uppercase tracking-widest text-stone-300 hover:text-white transition-colors ${i < children.length - 1 ? 'border-b border-stone-800' : ''}`}>
                      {child.name}
                    </a>
                  ))}
                </div>
              </div>
            );
          } else {
            return (
              <a href={`/${page.slug}`} data-section={page.slug} class="nav-item nav-link relative flex items-center px-5 text-sm tracking-wider text-stone-300 hover:text-white transition-colors duration-150 font-sans uppercase">
                {page.name}
              </a>
            );
          }
        })}

        <!-- Divider -->
        <div class="flex items-center px-2">
          <span class="w-px h-4 bg-stone-600"></span>
        </div>

        <!-- Muse -->
        <a href="/muse" data-section="muse" class="nav-item nav-link relative flex items-center px-5 text-sm tracking-wider text-stone-400 hover:text-white transition-colors duration-150 font-sans uppercase italic">
          Muse
        </a>

        <!-- Search -->
        <a href="/search" class="flex items-center px-4 h-full text-stone-400 hover:text-white transition-colors duration-150" aria-label="Search">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </a>

      </nav>

      <!-- ── Mobile hamburger ── -->
      <div class="flex items-center absolute right-6">
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span id="ham-1" class="block w-6 h-px bg-stone-300 transition-all duration-300 origin-center"></span>
          <span id="ham-2" class="block w-6 h-px bg-stone-300 transition-all duration-300"></span>
          <span id="ham-3" class="block w-6 h-px bg-stone-300 transition-all duration-300 origin-center"></span>
        </button>
      </div>

    </div><!-- end flex row -->
  </div><!-- end max-w container -->

  <!-- ── Mobile menu ── -->
  <div
    id="mobile-menu"
    class="lg:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    aria-hidden="true"
  >
    <nav class="border-t border-stone-800 divide-y divide-stone-800" aria-label="Mobile navigation">

      

      <!-- Nouse pages -->
      {nousePages.map((page) => {
        const children = getChildren(page.slug);
        if (children.length > 0) {
          return (
            <div class="mobile-accordion">
              <button class="mobile-accordion-btn w-full flex items-center justify-between px-6 py-4 font-sans text-xs uppercase tracking-widest text-stone-300 hover:text-white transition-colors" aria-expanded="false">
                <span class="flex items-center gap-3">
                  <span class={`w-2 h-2 rounded-full ${page.colour}`}></span>
                  {page.name}
                </span>
                <svg class="accordion-chevron w-3.5 h-3.5 text-stone-500 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="mobile-accordion-body overflow-hidden max-h-0 transition-all duration-300 bg-neutral-900">
                <a href={`/${page.slug}`} class="block pl-12 pr-6 py-3 font-sans text-xs uppercase tracking-widest text-stone-400 hover:text-white transition-colors border-b border-stone-800">All {page.name}</a>
                {children.map((child, i) => (
                  <a href={`/${child.slug}`} class={`block pl-12 pr-6 py-3 font-sans text-xs uppercase tracking-widest text-stone-400 hover:text-white transition-colors ${i < children.length - 1 ? 'border-b border-stone-800' : ''}`}>
                    {child.name}
                  </a>
                ))}
              </div>
            </div>
          );
        } else {
          return (
            <a href={`/${page.slug}`} class="flex items-center justify-between px-6 py-4 font-sans text-xs uppercase tracking-widest text-stone-300 hover:text-white hover:bg-neutral-900 transition-colors">
              {page.name}
              <span class={`w-2 h-2 rounded-full ${page.colour}`}></span>
            </a>
          );
        }
      })}

      <!-- Muse -->
      <a href="/muse" class="flex items-center justify-between px-6 py-4 font-sans text-xs uppercase tracking-widest text-stone-300 italic hover:text-white hover:bg-neutral-900 transition-colors">
        Muse
      </a>

      <!-- Search -->
      <a href="/search" class="flex items-center gap-3 px-6 py-4 font-sans text-xs uppercase tracking-widest text-stone-400 hover:text-white hover:bg-neutral-900 transition-colors border-t border-stone-700">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Search
      </a>

    </nav>
  </div>

</header>

<script>
  // ── Section colour map ──────────────────────────────────────────
  const sectionColours: Record<string, { bg: string }> = {
    default:  { bg: 'bg-neutral-950' },
    home:     { bg: 'bg-neutral-950' },
    news:     { bg: 'bg-sky-950'     },
    politics: { bg: 'bg-red-950'     },
    sport:    { bg: 'bg-emerald-950' },
    business: { bg: 'bg-amber-950'   },
    comment:  { bg: 'bg-violet-950'  },
    science:  { bg: 'bg-cyan-950'    },
  };

  const header = document.getElementById('nouse-nav')!;
  const allBgs = [...new Set(Object.values(sectionColours).map(c => c.bg))];

  function applySection(section: string) {
    const colours = sectionColours[section] ?? sectionColours.default;
    header.classList.remove(...allBgs);
    header.classList.add(colours.bg);
  }

  // Desktop: watch nav-item wrappers (covers both <a> and <div> items)
  document.querySelectorAll<HTMLElement>('.nav-item').forEach(item => {
    const section = item.dataset.section ?? 'default';
    item.addEventListener('mouseenter', () => applySection(section));
    item.addEventListener('mouseleave', () => applySection('default'));
  });

  // ── Mobile hamburger ────────────────────────────────────────────
  const btn    = document.getElementById('mobile-menu-btn')!;
  const menu   = document.getElementById('mobile-menu')!;
  const ham1   = document.getElementById('ham-1')!;
  const ham2   = document.getElementById('ham-2')!;
  const ham3   = document.getElementById('ham-3')!;
  let   isOpen = false;

  function recalcMenuHeight() {
    if (isOpen) menu.style.maxHeight = menu.scrollHeight + 'px';
  }

  btn.addEventListener('click', () => {
    isOpen = !isOpen;
    btn.setAttribute('aria-expanded', String(isOpen));
    menu.setAttribute('aria-hidden',  String(!isOpen));
    menu.style.maxHeight = isOpen ? menu.scrollHeight + 'px' : '0';
    ham1.style.transform = isOpen ? 'translateY(6px) rotate(45deg)'  : '';
    ham2.style.opacity   = isOpen ? '0' : '';
    ham3.style.transform = isOpen ? 'translateY(-6px) rotate(-45deg)' : '';
  });

  // ── Masthead collapse on scroll ─────────────────────────────────
  const banner       = document.getElementById('logo-banner')!;
  const navLogo      = document.getElementById('nav-logo')!;
  const bannerHeight = banner.scrollHeight;
  banner.style.maxHeight = bannerHeight + 'px';

  window.addEventListener('scroll', () => {
    if (window.innerWidth < 1024) return; // mobile: logo always visible, no banner
    if (window.scrollY > 0) {
      banner.style.maxHeight  = '0px';
      banner.style.opacity    = '0';
      navLogo.style.opacity   = '1';
    } else {
      banner.style.maxHeight  = bannerHeight + 'px';
      banner.style.opacity    = '1';
      navLogo.style.opacity   = '0';
    }
  }, { passive: true });

  // ── Mobile accordions ───────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.mobile-accordion').forEach(accordion => {
    const toggleBtn = accordion.querySelector<HTMLElement>('.mobile-accordion-btn')!;
    const body      = accordion.querySelector<HTMLElement>('.mobile-accordion-body')!;
    const chevron   = accordion.querySelector<HTMLElement>('.accordion-chevron')!;
    let   open      = false;

    toggleBtn.addEventListener('click', () => {
      open = !open;
      toggleBtn.setAttribute('aria-expanded', String(open));
      body.style.maxHeight = open ? body.scrollHeight + 'px' : '0';
      chevron.style.transform = open ? 'rotate(180deg)' : '';
      // Let parent menu know its height changed
      setTimeout(recalcMenuHeight, 310);
    });
  });
</script>