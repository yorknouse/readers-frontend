          <tspan style="letter-spacing:.08em" x="0" y="0">E</tspan><tspan style="letter-spacing:-.03em" x="3.73" y="0">s</tspan><tspan style="letter-spacing:-.03em" x="6.09" y="0">t</tspan><tspan style="letter-spacing:.02em" x="8.08" y="0">.</tspan><tspan style="letter-spacing:.01em" x="9.57" y="0"> </tspan><tspan style="letter-spacing:-.03em" x="11.05" y="0">1964</tspan>
        </text>
      </svg>
    </a>
  </div>
</div>

<header
  id="nouse-nav"
  class="sticky top-0 z-50 relative bg-neutral-950 font-serif transition-colors duration-300"
>
<div class="max-w-screen-2xl mx-auto px-6">

    <div class="relative flex items-center justify-center h-16">

      <!-- ── Scrolled-in logo ── -->
      <a
        id="nav-logo"
        href="/"
        aria-label="Nouse home"
        class="absolute left-1/2 -translate-x-1/2 opacity-100 lg:left-0 lg:translate-x-0 lg:opacity-0 transition-opacity duration-300 hover:opacity-70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 rounded-sm"
      >
        <svg class="w-30 h-auto fill-stone-100" viewBox="0 0 291.63 55.8" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
