---
import type { Publication } from '@/types/content';
import { pages } from '@/config/pages';

const { publication } = Astro.props as { publication: Publication };

const getChildren = (slug: string) => pages.filter(p => p.parent_slug === slug);
const nousePages  = pages.filter(p => p.publication === 'nouse' && !p.parent_slug);
---

<!-- ── Masthead logo banner ── -->
<div
  id="logo-banner"
  class="hidden lg:block bg-white border-b border-stone-200 overflow-hidden"
  style="transition: max-height 0.35s ease-in-out, opacity 0.35s ease-in-out;"
>
  <div class="max-w-screen-3xl mx-auto px-6 py-7 flex justify-center">
    <a
      href="/"
      aria-label="Nouse home"
      class="hover:opacity-70 transition-opacity duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 rounded-sm"
    >
